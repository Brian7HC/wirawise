# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kikuyu_chatbot
DB_USER=your_postgresql_username
DB_PASSWORD=your_postgresql_password

DATABASE_URL=postgresql://username:password@localhost:5432/kikuyu_chatbot

# ============================================
# APPLICATION SETTINGS
# ============================================
ENV=development
DEBUG=True

API_HOST=0.0.0.0
API_PORT=8000

# ============================================
# SPEECH MODELS
# ============================================
STT_MODEL=medium
TTS_ENGINE=coqui

# ============================================
# AUDIO SETTINGS
# ============================================
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
MAX_AUDIO_SIZE_MB=10

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
